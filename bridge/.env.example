# =========================================================
# QUOTEX BRIDGE — config local
# Copie pra .env e preencha
# =========================================================

# Sua conta Quotex (DEMO recomendado pra testes)
QUOTEX_EMAIL=seu_email@gmail.com
QUOTEX_PASSWORD=sua_senha
QUOTEX_ACCOUNT_TYPE=PRACTICE      # PRACTICE (demo) ou REAL

# Backend ChatFunnel (a URL pública do seu deploy)
WEBHOOK_BASE_URL=https://seu-backend.onrender.com
ROOM_ID=1                          # id da sala (mostrado no painel)
ROOM_SECRET=wh_xxxxxxxxxxxxxxxx    # copie da aba Webhook

# Pares a monitorar (Quotex usa o sufixo _otc pra fins de semana)
PAIRS=EURUSD_otc,GBPUSD_otc,USDJPY_otc,AUDCAD_otc,EURJPY_otc

# Estratégia
STRATEGY=rsi_oversold_overbought   # rsi_oversold_overbought | ema_crossover | multi_confluence
MIN_CONFIDENCE=65
COOLDOWN_SECONDS=300               # mesmo par só reanalisar após N segundos

# Timeframe (em segundos): 60 = M1, 300 = M5
CANDLE_PERIOD=60
CANDLE_COUNT=60                    # histórico pra calcular indicadores

# Heartbeat (em segundos)
HEARTBEAT_INTERVAL=30
